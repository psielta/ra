# Ports (range 14001–15000)
PORT=14001
POSTGRES_PORT=14002
PRISMA_STUDIO_PORT=14003

# Database
# Local (Postgres via Docker on host port 14002):
DATABASE_URL="postgresql://postgres:postgres@localhost:14002/ra?schema=public"
# Inside Docker Compose (used automatically by the app service):
# DATABASE_URL="postgresql://postgres:postgres@postgres:5432/ra?schema=public"

# Auth.js
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:14001"

# Sentry (optional in development)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:14001"
LOG_LEVEL="info"