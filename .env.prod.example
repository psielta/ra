# Production environment for /opt/ra.
# Copy to .env on the VPS and replace every change-me value.

TZ=America/Sao_Paulo

# Database
POSTGRES_USER=ra
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ra_prod
DATABASE_URL=postgresql://ra:change-me@ra-postgres:5432/ra_prod?schema=public

# Auth.js
AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
AUTH_URL=https://ra.mateussalgueiro.com.br
NEXT_PUBLIC_APP_URL=https://ra.mateussalgueiro.com.br

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=psielta@gmail.com
SMTP_PASS=change-me
EMAIL_FROM=Ra <psielta@gmail.com>

# Object storage
MINIO_ENDPOINT=ra-minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=raadmin
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=ra-media
MINIO_PUBLIC_URL=https://ra.mateussalgueiro.com.br
NGINX_MEDIA_URL=https://ra.mateussalgueiro.com.br

# Queue
RABBITMQ_DEFAULT_USER=ra
RABBITMQ_DEFAULT_PASS=change-me
RABBITMQ_URL=amqp://ra:change-me@ra-rabbitmq:5672

# Realtime
REDIS_URL=redis://ra-redis:6379

# Worker callback
WORKER_API_TOKEN=change-me
WORKER_API_URL=http://ra-app:3000
WORKER_METRICS_URL=http://ra-worker:14010/metrics

# Optional observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

LOG_LEVEL=info
