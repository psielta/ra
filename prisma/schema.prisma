generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  JOB
}

enum NotificationCategory {
  SYSTEM
  MEDIA
  ACCOUNT
}

enum MediaType {
  AUDIO
  VIDEO
}

enum TranscodeJobStatus {
  PROCESSING
  READY
  ERROR
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  notifications       Notification[]
  passwordResetTokens PasswordResetToken[]
  mediaAssets         MediaAsset[]
  transcodeJobs       TranscodeJob[]
  series              Series[]
  mediaAccesses       MediaAccess[]
}

model Series {
  id          String   @id @default(cuid())
  userId      String
  title       String
  slug        String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  resources MediaAsset[]

  @@unique([userId, slug])
  @@index([userId, createdAt(sort: Desc)])
}

model MediaAsset {
  id           String    @id @default(cuid())
  userId       String
  seriesId     String?
  title        String?
  description  String?   @db.Text
  mediaType    MediaType
  mimeType     String
  originalKey  String
  playbackUrl  String?
  durationSec  Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  series  Series?        @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  jobs    TranscodeJob[]
  accesses MediaAccess[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([seriesId, createdAt(sort: Desc)])
}

model MediaAccess {
  id           String   @id @default(cuid())
  userId       String
  mediaAssetId String
  accessedAt   DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaAsset MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaAssetId])
  @@index([userId, accessedAt(sort: Desc)])
}

model TranscodeJob {
  id           String             @id @default(cuid())
  userId       String
  mediaAssetId String
  status       TranscodeJobStatus @default(PROCESSING)
  storageKey   String
  errorMessage String?            @db.Text
  progress     Float              @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  completedAt  DateTime?

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaAsset MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([mediaAssetId])
  @@index([status, createdAt(sort: Desc)])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Notification {
  id        String               @id @default(cuid())
  userId    String
  type      NotificationType     @default(INFO)
  category  NotificationCategory @default(SYSTEM)
  title     String
  message   String               @db.Text
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}